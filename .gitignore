# ============================
# Unified .gitignore
# Covers Flutter, Node.js, Arduino/ESP32, and general tooling
# ============================

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Flutter / Dart ---
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
**/doc/api/
**/ios/Flutter/.last_build_id
app.*.symbols
app.*.map.json

# --- Android / iOS build artifacts ---
/android/app/debug
/android/app/profile
/android/app/release

# --- General tooling ---
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# --- IntelliJ / VS Code ---
*.iml
*.ipr
*.iws
.idea/
.vscode/

# --- OS files ---
Thumbs.db
